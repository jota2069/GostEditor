root = true

[*]
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

[*.cs]
indent_style = space
indent_size = 4
dotnet_style_var_for_built_in_types = false:warning
dotnet_style_var_when_type_is_apparent = false:warning
dotnet_style_var_elsewhere = false:warning

[*.{axaml,xaml}]
indent_style = space
indent_size = 4

[*.{csproj,sln}]
indent_style = space
indent_size = 2