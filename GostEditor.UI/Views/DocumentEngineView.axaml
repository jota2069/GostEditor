<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="GostEditor.UI.Views.DocumentEngineView">

    <UserControl.ContextMenu>
        <ContextMenu>
            <MenuItem Header="Копировать" InputGesture="Ctrl+C" Click="OnCopyClick"/>
            <MenuItem Header="Вырезать" InputGesture="Ctrl+X" Click="OnCutClick"/>
            <MenuItem Header="Вставить" InputGesture="Ctrl+V" Click="OnPasteClick"/>
            <Separator/>
            <MenuItem Header="Выделить всё" InputGesture="Ctrl+A" Click="OnSelectAllClick"/>
            <Separator/>
            <MenuItem Header="Отменить" InputGesture="Ctrl+Z" Click="OnUndoClick"/>
        </ContextMenu>
    </UserControl.ContextMenu>

    <ScrollViewer Background="#F5F5F5"
                  HorizontalScrollBarVisibility="Auto"
                  VerticalScrollBarVisibility="Auto">

        <StackPanel x:Name="PagesStackPanel"
                    Orientation="Vertical"
                    Spacing="32"
                    Margin="0,32"
                    HorizontalAlignment="Center"/>

    </ScrollViewer>
</UserControl>
