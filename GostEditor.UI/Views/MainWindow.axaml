<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:GostEditor.UI.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="600"
        x:Class="GostEditor.UI.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="GostEditor — ГОСТ 7.32-2017"
        MinWidth="800" MinHeight="500">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <DockPanel>

        <!-- Панель кнопок сверху -->
        <StackPanel DockPanel.Dock="Top"
                    Orientation="Horizontal"
                    Spacing="8"
                    Margin="12,10">

            <Button Content="Новый"
                    Command="{Binding NewDocumentCommand}"
                    IsEnabled="{Binding !IsBusy}"/>

            <Button Content="Открыть"
                    Command="{Binding LoadDocumentCommand}"
                    IsEnabled="{Binding !IsBusy}"/>

            <Button Content="Сохранить"
                    Command="{Binding SaveDocumentCommand}"
                    IsEnabled="{Binding !IsBusy}"/>

            <Button Content="Экспорт в DOCX"
                    Command="{Binding ExportToDocxCommand}"
                    IsEnabled="{Binding !IsBusy}"/>

            <Button Content="Парсить код"
                    Command="{Binding ParseCodeFolderCommand}"
                    IsEnabled="{Binding !IsBusy}"/>

            <Button Content="Вставить нормализованный"
                    Command="{Binding PasteNormalizedCommand}"
                    IsEnabled="{Binding !IsBusy}"/>

        </StackPanel>

        <!-- Статусная строка снизу -->
        <TextBlock DockPanel.Dock="Bottom"
                   Text="{Binding StatusMessage}"
                   Margin="12,6"
                   FontSize="12"
                   Opacity="0.7"/>

        <!-- Основной контент -->
        <ScrollViewer>
            <StackPanel Margin="12,0,12,12" Spacing="10">

                <!-- Титульный лист -->
                <TextBlock Text="Титульный лист"
                           FontSize="16"
                           FontWeight="Bold"
                           Margin="0,8,0,4"/>

                <TextBox Watermark="Университет"
                         Text="{Binding University}"/>

                <TextBox Watermark="Кафедра"
                         Text="{Binding Department}"/>

                <TextBox Watermark="Название работы"
                         Text="{Binding WorkTitle}"/>

                <TextBox Watermark="ФИО студента"
                         Text="{Binding StudentName}"/>

                <TextBox Watermark="Номер группы"
                         Text="{Binding GroupNumber}"/>

                <TextBox Watermark="ФИО преподавателя"
                         Text="{Binding TeacherName}"/>

                <!-- Листинги кода -->
                <TextBlock Text="Файлы кода"
                           FontSize="16"
                           FontWeight="Bold"
                           Margin="0,12,0,4"/>

                <ListBox ItemsSource="{Binding CodeListings}"
                         MaxHeight="200">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <CheckBox IsChecked="{Binding IsSelected}"/>
                                <TextBlock Text="{Binding RelativePath}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

            </StackPanel>
        </ScrollViewer>

    </DockPanel>

</Window>