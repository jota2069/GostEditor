<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:GostEditor.UI.ViewModels"
        xmlns:models="using:GostEditor.Core.Models"
        xmlns:views="using:GostEditor.UI.Views"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:System="clr-namespace:System;assembly=mscorlib"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        x:Class="GostEditor.UI.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="{Binding WindowTitle}"
        MinWidth="1000" MinHeight="650"
        Background="#F5F5F5">

    <Window.Styles>
        <Style Selector="Button.toolbar">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="#CCCCCC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,5"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#333333"/>
            <Setter Property="CornerRadius" Value="4"/>
        </Style>
        <Style Selector="Button.toolbar:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#EBEBEB"/>
        </Style>

        <Style Selector="Button.accent">
            <Setter Property="Background" Value="#2B579A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14,6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="CornerRadius" Value="4"/>
        </Style>
        <Style Selector="Button.accent:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#1E3F7A"/>
        </Style>

        <Style Selector="ListBoxItem">
            <Setter Property="Padding" Value="10,7"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="4"/>
        </Style>
        <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
            <Setter Property="Background" Value="#DDEAFF"/>
        </Style>
        <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#EEEEEE"/>
        </Style>

        <Style Selector="TextBox.titleInput">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="MinHeight" Value="0"/>
            <Setter Property="MinWidth" Value="0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style Selector="TextBox.titleInput:focus /template/ Border#PART_BorderElement">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="#F0F8FF"/>
        </Style>
    </Window.Styles>

    <DockPanel>
        <Border DockPanel.Dock="Top"
                Background="White"
                BorderBrush="#E0E0E0"
                BorderThickness="0,0,0,1"
                Padding="12,8">
            <StackPanel Orientation="Horizontal" Spacing="6">

                <TextBlock Text="GostEditor"
                           FontSize="15"
                           FontWeight="Bold"
                           Foreground="#2B579A"
                           VerticalAlignment="Center"
                           Margin="0,0,16,0"/>

                <Button Content="Новый" Classes="toolbar" Command="{Binding NewDocumentCommand}" IsEnabled="{Binding !IsBusy}"/>
                <Button Content="Открыть" Classes="toolbar" Command="{Binding LoadDocumentCommand}" IsEnabled="{Binding !IsBusy}"/>
                <Button Content="Сохранить" Classes="toolbar" Command="{Binding SaveDocumentCommand}" IsEnabled="{Binding !IsBusy}"/>

                <Border Width="1" Background="#E0E0E0" Margin="4,0"/>

                <Button Content="Экспорт в DOCX" Classes="accent" Command="{Binding ExportToDocxCommand}" IsEnabled="{Binding !IsBusy}"/>

                <Border Width="1" Background="#E0E0E0" Margin="4,0"/>

                <Button Content="Ж" FontWeight="Bold" Classes="toolbar" Focusable="False" Click="OnBoldClick" ToolTip.Tip="Жирный текст"/>
                <Button Content="К" FontStyle="Italic" Classes="toolbar" Focusable="False" Click="OnItalicClick" ToolTip.Tip="Курсив"/>

                <Border Width="1" Background="#E0E0E0" Margin="4,0"/>

                <Button Content="Лево" Classes="toolbar" Focusable="False" Click="OnAlignLeftClick"/>
                <Button Content="Центр" Classes="toolbar" Focusable="False" Click="OnAlignCenterClick"/>
                <Button Content="Право" Classes="toolbar" Focusable="False" Click="OnAlignRightClick"/>
                <Button Content="Ширина" Classes="toolbar" Focusable="False" Click="OnAlignJustifyClick"/>

                <Border Width="1" Background="#E0E0E0" Margin="4,0"/>

                <ComboBox x:Name="FontSizeComboBox" Width="70" VerticalAlignment="Center" SelectionChanged="OnFontSizeSelectionChanged" SelectedIndex="2" Classes="toolbar">
                    <ComboBoxItem Content="10"/>
                    <ComboBoxItem Content="12"/>
                    <ComboBoxItem Content="14"/>
                    <ComboBoxItem Content="16"/>
                    <ComboBoxItem Content="18"/>
                    <ComboBoxItem Content="20"/>
                    <ComboBoxItem Content="24"/>
                </ComboBox>

                <Border Width="1" Background="#E0E0E0" Margin="4,0"/>

                <Button Content="Парсить код" Classes="toolbar" Command="{Binding ParseCodeFolderCommand}" IsEnabled="{Binding !IsBusy}"/>
                <Button Content="Вставить текст" Classes="toolbar" Command="{Binding PasteNormalizedCommand}" IsEnabled="{Binding !IsBusy}"/>

            </StackPanel>
        </Border>

        <Border DockPanel.Dock="Bottom" Background="White" BorderBrush="#E0E0E0" BorderThickness="0,1,0,0" Padding="16,5">
            <DockPanel>
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" Spacing="5" Margin="10,0,0,0">
                    <Button Content="Новый" Click="OnNewDocumentClick"/>
                    <Button Content="Убрать форматирование" Click="OnClearFormattingClick"/>
                    <TextBlock Text="Начать с листа:" VerticalAlignment="Center" Margin="10,0,5,0"/>
                    <NumericUpDown x:Name="StartPagePicker" Minimum="1" Maximum="999" Value="1" FormatString="0" ValueChanged="OnStartPageNumberChanged" Width="80"/>
                    <TextBlock x:Name="CurrentStartPageLabel" Text="(Сейчас: 1)" VerticalAlignment="Center" Foreground="#888888" Margin="5,0,0,0"/>
                </StackPanel>

                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                    <TextBlock Text="{Binding StatusMessage}" Foreground="#888888" FontSize="12" VerticalAlignment="Center"/>
                    <ProgressBar IsVisible="{Binding IsBusy}" IsIndeterminate="True" Width="120" Height="3" VerticalAlignment="Center"/>
                    <TextBlock Text="Масштаб:" VerticalAlignment="Center" Foreground="#888888" FontSize="12" Margin="10,0,0,0"/>
                    <Slider Minimum="0.5" Maximum="2.0" Value="{Binding ZoomLevel}" Width="100" VerticalAlignment="Center" TickFrequency="0.1" IsSnapToTickEnabled="True"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid ColumnDefinitions="220,1,*">

            <Border Grid.Column="0" Background="White" BorderBrush="#E0E0E0" BorderThickness="0,0,1,0">
                <DockPanel>
                    <Border DockPanel.Dock="Top" Padding="12,10" BorderBrush="#F0F0F0" BorderThickness="0,0,0,1">
                        <TextBlock Text="СОДЕРЖАНИЕ" Foreground="#AAAAAA" FontSize="10" FontWeight="Bold"/>
                    </Border>

                    <Button DockPanel.Dock="Bottom" Content="+ Новый раздел" Classes="toolbar" Command="{Binding AddSectionCommand}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Margin="8" Padding="8,6"/>

                    <ListBox ItemsSource="{Binding Sections}" SelectedItem="{Binding SelectedSection}" Background="Transparent" BorderThickness="0" Margin="6,4">
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="models:DocumentSection">
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBlock Grid.Column="0" Text="{Binding Title}" Foreground="#333333" FontSize="13" VerticalAlignment="Center"/>
                                    <Button Grid.Column="1" Content="×" Command="{Binding $parent[Window].DataContext.DeleteSectionCommand}" CommandParameter="{Binding}" x:CompileBindings="False" Background="Transparent" BorderThickness="0" Foreground="#AAAAAA" FontSize="16" Padding="4,0" VerticalAlignment="Center"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <Border Grid.Column="1" Background="#E0E0E0"/>

            <TabControl x:Name="MainTabs" Grid.Column="2" Background="#F5F5F5" BorderThickness="0">

                <TabItem Header="Редактор">
                    <Grid Background="#F5F5F5">
                        <LayoutTransformControl>
                            <LayoutTransformControl.LayoutTransform>
                                <ScaleTransform ScaleX="{Binding ZoomLevel}" ScaleY="{Binding ZoomLevel}"/>
                            </LayoutTransformControl.LayoutTransform>
                            <views:DocumentEngineView x:Name="MainEditor" />
                        </LayoutTransformControl>
                    </Grid>
                </TabItem>

              <TabItem Header="Титульный лист">
                    <Grid ColumnDefinitions="380, *">

                        <ScrollViewer Grid.Column="0" Background="#F5F5F5">
                            <Border Background="White" BorderBrush="#CCCCCC" BorderThickness="1" Padding="20" Margin="20" CornerRadius="4" VerticalAlignment="Top">
                                <StackPanel Spacing="14">
                                    <TextBlock Text="Данные титульного листа" FontSize="16" FontWeight="Bold" Foreground="#1A1A1A" Margin="0,0,0,4"/>

                                    <TextBox Text="{Binding University}" Watermark="Университет (например, ТвГТУ)" Background="White"/>
                                    <TextBox Text="{Binding Department}" Watermark="Кафедра" Background="White"/>
                                    <TextBox Text="{Binding Discipline}" Watermark="Дисциплина" Background="White"/>
                                    <TextBox Text="{Binding WorkType}" Watermark="Тип работы" Background="White"/>
                                    <TextBox Text="{Binding WorkTitle}" Watermark="Тема работы" Background="White"/>
                                    <TextBox Text="{Binding GroupNumber}" Watermark="Номер группы" Background="White"/>

                                    <Grid ColumnDefinitions="*, Auto">
                                        <TextBox Grid.Column="0" Text="{Binding StudentName}" AcceptsReturn="True" MinHeight="55" Watermark="ФИО студента(ов)" Background="White" TextWrapping="Wrap"/>
                                        <Button Grid.Column="1" Content="+" Command="{Binding AddStudentCommand}" Classes="accent" VerticalAlignment="Top" Margin="8,0,0,0" Width="32" Height="32" HorizontalContentAlignment="Center"/>
                                    </Grid>

                                    <TextBox Text="{Binding TeacherName}" Watermark="ФИО преподавателя" Background="White"/>

                                    <Grid ColumnDefinitions="*, 80" Margin="0,4,0,0">
                                        <TextBox Grid.Column="0" Text="{Binding City}" Watermark="Город" Background="White" Margin="0,0,5,0"/>
                                        <NumericUpDown Grid.Column="1" Value="{Binding Year}" Minimum="1900" Maximum="2100" FormatString="0" Background="White"/>
                                    </Grid>

                                    <Button Content="Сбросить по умолчанию" Command="{Binding ResetTitlePageCommand}" Classes="toolbar" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Margin="0,15,0,0" />
                                </StackPanel>
                            </Border>
                        </ScrollViewer>

                        <ScrollViewer Grid.Column="1" Background="#E0E0E0" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                            <Border Padding="40" HorizontalAlignment="Center" VerticalAlignment="Top">
                                <LayoutTransformControl>
                                    <LayoutTransformControl.LayoutTransform>
                                        <ScaleTransform ScaleX="0.95" ScaleY="0.95"/>
                                    </LayoutTransformControl.LayoutTransform>

                                    <Border Width="794" Height="1123" Background="White" BoxShadow="0 4 15 0 #33000000">

                                        <Grid Margin="113,76,57,76">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <StackPanel Grid.Row="0" HorizontalAlignment="Stretch" Spacing="0">
                                                <TextBlock Text="Министерство науки и высшего образования Российской Федерации" TextAlignment="Center" FontSize="19" FontFamily="Times New Roman, Liberation Serif, serif"/>
                                                <TextBlock Text="Федеральное государственное бюджетное образовательное учреждение" TextAlignment="Center" FontSize="19" FontFamily="Times New Roman, Liberation Serif, serif"/>
                                                <TextBlock Text="высшего образования" TextAlignment="Center" FontSize="19" FontFamily="Times New Roman, Liberation Serif, serif"/>

                                                <TextBox Classes="titleInput" Text="{Binding University}" TextAlignment="Center" FontSize="19" FontFamily="Times New Roman, Liberation Serif, serif" FontWeight="Bold"/>
                                                <TextBox Classes="titleInput" Text="{Binding Department}" TextAlignment="Center" FontSize="19" FontFamily="Times New Roman, Liberation Serif, serif" Margin="0,15,0,0"/>
                                            </StackPanel>

                                            <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Stretch" Spacing="0">
                                                <TextBox Classes="titleInput" Text="{Binding WorkType}" TextAlignment="Center" FontSize="19" FontFamily="Times New Roman, Liberation Serif, serif"/>
                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                    <TextBlock Text="по дисциплине «" FontSize="19" FontFamily="Times New Roman, Liberation Serif, serif" VerticalAlignment="Center"/>
                                                    <TextBox Classes="titleInput" Text="{Binding Discipline}" FontSize="19" FontFamily="Times New Roman, Liberation Serif, serif" VerticalAlignment="Center"/>
                                                    <TextBlock Text="»" FontSize="19" FontFamily="Times New Roman, Liberation Serif, serif" VerticalAlignment="Center"/>
                                                </StackPanel>
                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                    <TextBlock Text="на тему « " FontSize="19" FontFamily="Times New Roman, Liberation Serif, serif" VerticalAlignment="Center"/>
                                                    <TextBox Classes="titleInput" Text="{Binding WorkTitle}" FontSize="19" FontFamily="Times New Roman, Liberation Serif, serif" TextWrapping="Wrap" MaxWidth="450" VerticalAlignment="Center"/>
                                                    <TextBlock Text=" »" FontSize="19" FontFamily="Times New Roman, Liberation Serif, serif" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </StackPanel>

                                            <StackPanel Grid.Row="2" HorizontalAlignment="Right" Margin="0,0,0,40" Spacing="0">
                                                <TextBlock Text="Выполнил:" FontSize="19" FontFamily="Times New Roman, Liberation Serif, serif" FontWeight="Bold" TextAlignment="Left"/>
                                                <TextBlock Text="студент группы" FontSize="19" FontFamily="Times New Roman, Liberation Serif, serif" TextAlignment="Left"/>

                                                <TextBox Classes="titleInput" Text="{Binding GroupNumber}" FontSize="19" FontFamily="Times New Roman, Liberation Serif, serif" TextAlignment="Left" TextWrapping="Wrap"/>
                                                <TextBox Classes="titleInput" Text="{Binding StudentName}" AcceptsReturn="True" FontSize="19" FontFamily="Times New Roman, Liberation Serif, serif" TextAlignment="Left" TextWrapping="Wrap"/>

                                                <TextBlock Text="Принял:" FontSize="19" FontFamily="Times New Roman, Liberation Serif, serif" FontWeight="Bold" Margin="0,15,0,0" TextAlignment="Left"/>
                                                <TextBox Classes="titleInput" Text="{Binding TeacherName}" FontSize="19" FontFamily="Times New Roman, Liberation Serif, serif" TextAlignment="Left" TextWrapping="Wrap"/>
                                            </StackPanel>

                                            <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" Spacing="0">
                                                <TextBox Classes="titleInput" Text="{Binding City}" FontSize="19" FontFamily="Times New Roman, Liberation Serif, serif" VerticalAlignment="Center" TextAlignment="Right"/>
                                                <TextBlock Text=", " FontSize="19" FontFamily="Times New Roman, Liberation Serif, serif" VerticalAlignment="Center"/>
                                                <TextBox Classes="titleInput" Text="{Binding Year}" FontSize="19" FontFamily="Times New Roman, Liberation Serif, serif" VerticalAlignment="Center"/>
                                                <TextBlock Text=" г." FontSize="19" FontFamily="Times New Roman, Liberation Serif, serif" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Grid>

                                    </Border>
                                </LayoutTransformControl>
                            </Border>
                        </ScrollViewer>
                    </Grid>
                </TabItem>

            </TabControl>
        </Grid>
    </DockPanel>
</Window>
