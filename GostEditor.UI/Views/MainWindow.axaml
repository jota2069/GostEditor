<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:GostEditor.UI.ViewModels"
        xmlns:models="using:GostEditor.Core.Models"
        xmlns:views="using:GostEditor.UI.Views"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        x:Class="GostEditor.UI.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="{Binding WindowTitle}"
        MinWidth="1000" MinHeight="650"
        Background="#F5F5F5">

    <Window.Styles>
        <Style Selector="Button.toolbar">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="#CCCCCC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,5"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#333333"/>
            <Setter Property="CornerRadius" Value="4"/>
        </Style>
        <Style Selector="Button.toolbar:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#EBEBEB"/>
        </Style>

        <Style Selector="Button.accent">
            <Setter Property="Background" Value="#2B579A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14,6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="CornerRadius" Value="4"/>
        </Style>
        <Style Selector="Button.accent:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#1E3F7A"/>
        </Style>

        <Style Selector="ListBoxItem">
            <Setter Property="Padding" Value="10,7"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="4"/>
        </Style>
        <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
            <Setter Property="Background" Value="#DDEAFF"/>
        </Style>
        <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#EEEEEE"/>
        </Style>
    </Window.Styles>

    <DockPanel>
        <Border DockPanel.Dock="Top"
                Background="White"
                BorderBrush="#E0E0E0"
                BorderThickness="0,0,0,1"
                Padding="12,8">
            <StackPanel Orientation="Horizontal" Spacing="6">

                <TextBlock Text="GostEditor"
                           FontSize="15"
                           FontWeight="Bold"
                           Foreground="#2B579A"
                           VerticalAlignment="Center"
                           Margin="0,0,16,0"/>

                <Button Content="Новый"
                        Classes="toolbar"
                        Command="{Binding NewDocumentCommand}"
                        IsEnabled="{Binding !IsBusy}"/>

                <Button Content="Открыть"
                        Classes="toolbar"
                        Command="{Binding LoadDocumentCommand}"
                        IsEnabled="{Binding !IsBusy}"/>

                <Button Content="Сохранить"
                        Classes="toolbar"
                        Command="{Binding SaveDocumentCommand}"
                        IsEnabled="{Binding !IsBusy}"/>

                <Border Width="1" Background="#E0E0E0" Margin="4,0"/>

                <Button Content="Экспорт в DOCX"
                        Classes="accent"
                        Command="{Binding ExportToDocxCommand}"
                        IsEnabled="{Binding !IsBusy}"/>

                <Border Width="1" Background="#E0E0E0" Margin="4,0"/>

                <Button Content="Ж"
                        FontWeight="Bold"
                        Classes="toolbar"
                        Focusable="False"
                        Click="OnBoldClick"
                        ToolTip.Tip="Жирный текст"/>

                <Button Content="К"
                        FontStyle="Italic"
                        Classes="toolbar"
                        Focusable="False"
                        Click="OnItalicClick"
                        ToolTip.Tip="Курсив"/>

                <Border Width="1" Background="#E0E0E0" Margin="4,0"/>

                <Button Content="Лево" Classes="toolbar" Focusable="False" Click="OnAlignLeftClick"/>
                <Button Content="Центр" Classes="toolbar" Focusable="False" Click="OnAlignCenterClick"/>
                <Button Content="Право" Classes="toolbar" Focusable="False" Click="OnAlignRightClick"/>
                <Button Content="Ширина" Classes="toolbar" Focusable="False" Click="OnAlignJustifyClick"/>

                <Border Width="1" Background="#E0E0E0" Margin="4,0"/>

                <Button Content="Парсить код"
                        Classes="toolbar"
                        Command="{Binding ParseCodeFolderCommand}"
                        IsEnabled="{Binding !IsBusy}"/>

                <Button Content="Вставить текст"
                        Classes="toolbar"
                        Command="{Binding PasteNormalizedCommand}"
                        IsEnabled="{Binding !IsBusy}"/>

            </StackPanel>
        </Border>

        <Border DockPanel.Dock="Bottom"
                Background="White"
                BorderBrush="#E0E0E0"
                BorderThickness="0,1,0,0"
                Padding="16,5">
            <DockPanel>
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" Spacing="5" Margin="10,0,0,0">
                    <Button Content="Новый" Click="OnNewDocumentClick"/>
                    <Button Content="Убрать форматирование" Click="OnClearFormattingClick"/>

                    <TextBlock Text="Начать с листа:" VerticalAlignment="Center" Margin="10,0,5,0"/>
                    <NumericUpDown x:Name="StartPagePicker" Minimum="1" Maximum="999" Value="1" FormatString="0"
                                   ValueChanged="OnStartPageNumberChanged" Width="80"/>

                    <TextBlock x:Name="CurrentStartPageLabel" Text="(Сейчас: 1)" VerticalAlignment="Center" Foreground="#888888" Margin="5,0,0,0"/>
                </StackPanel>

                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                    <TextBlock Text="{Binding StatusMessage}"
                               Foreground="#888888"
                               FontSize="12"
                               VerticalAlignment="Center"/>

                    <ProgressBar IsVisible="{Binding IsBusy}"
                                 IsIndeterminate="True"
                                 Width="120" Height="3"
                                 VerticalAlignment="Center"/>

                    <TextBlock Text="Масштаб:" VerticalAlignment="Center" Foreground="#888888" FontSize="12" Margin="10,0,0,0"/>
                    <Slider Minimum="0.5" Maximum="2.0" Value="{Binding ZoomLevel}"
                            Width="100" VerticalAlignment="Center"
                            TickFrequency="0.1" IsSnapToTickEnabled="True"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid ColumnDefinitions="220,1,*">

            <Border Grid.Column="0"
                    Background="White"
                    BorderBrush="#E0E0E0"
                    BorderThickness="0,0,1,0">
                <DockPanel>
                    <Border DockPanel.Dock="Top"
                            Padding="12,10"
                            BorderBrush="#F0F0F0"
                            BorderThickness="0,0,0,1">
                        <TextBlock Text="СОДЕРЖАНИЕ"
                                   Foreground="#AAAAAA"
                                   FontSize="10"
                                   FontWeight="Bold"/>
                    </Border>

                    <Button DockPanel.Dock="Bottom"
                            Content="+ Новый раздел"
                            Classes="toolbar"
                            Command="{Binding AddSectionCommand}"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Center"
                            Margin="8" Padding="8,6"/>

                    <ListBox ItemsSource="{Binding Sections}"
                             SelectedItem="{Binding SelectedSection}"
                             Background="Transparent"
                             BorderThickness="0"
                             Margin="6,4">
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="models:DocumentSection">
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBlock Grid.Column="0"
                                               Text="{Binding Title}"
                                               Foreground="#333333"
                                               FontSize="13"
                                               VerticalAlignment="Center"/>
                                    <Button Grid.Column="1"
                                            Content="×"
                                            Command="{Binding $parent[Window].DataContext.DeleteSectionCommand}"
                                            CommandParameter="{Binding}"
                                            x:CompileBindings="False"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Foreground="#AAAAAA"
                                            FontSize="16"
                                            Padding="4,0"
                                            VerticalAlignment="Center"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <Border Grid.Column="1" Background="#E0E0E0"/>

            <TabControl Grid.Column="2"
                        Background="#F5F5F5"
                        BorderThickness="0">

                <TabItem Header="Редактор">
                    <Grid Background="#F5F5F5">
                        <LayoutTransformControl>
                            <LayoutTransformControl.LayoutTransform>
                                <ScaleTransform ScaleX="{Binding ZoomLevel}" ScaleY="{Binding ZoomLevel}"/>
                            </LayoutTransformControl.LayoutTransform>

                            <views:DocumentEngineView x:Name="MainEditor" />

                        </LayoutTransformControl>
                    </Grid>
                </TabItem>

                <TabItem Header="Титульный лист">
                    <ScrollViewer Background="#F5F5F5" Padding="0,32,0,32">
                        <Border Background="White" BorderBrush="#CCCCCC" BorderThickness="1" Width="600" HorizontalAlignment="Center" Padding="48">
                            <StackPanel Spacing="14">
                                <TextBlock Text="Титульный лист" FontSize="18" FontWeight="Bold" Foreground="#1A1A1A" Margin="0,0,0,8"/>
                                <TextBlock Text="Университет" Foreground="#999999" FontSize="11"/>
                                <TextBox Text="{Binding University}" Watermark="Название университета" Background="White"/>
                                <TextBlock Text="Кафедра" Foreground="#999999" FontSize="11"/>
                                <TextBox Text="{Binding Department}" Watermark="Название кафедры" Background="White"/>
                                <TextBlock Text="Название работы" Foreground="#999999" FontSize="11"/>
                                <TextBox Text="{Binding WorkTitle}" Watermark="Тема лабораторной работы" Background="White"/>
                                <TextBlock Text="ФИО студента" Foreground="#999999" FontSize="11"/>
                                <TextBox Text="{Binding StudentName}" Watermark="Иванов Иван Иванович" Background="White"/>
                                <TextBlock Text="Номер группы" Foreground="#999999" FontSize="11"/>
                                <TextBox Text="{Binding GroupNumber}" Watermark="ИВТ-21" Background="White"/>
                                <TextBlock Text="ФИО преподавателя" Foreground="#999999" FontSize="11"/>
                                <TextBox Text="{Binding TeacherName}" Watermark="Петров Пётр Петрович" Background="White"/>
                            </StackPanel>
                        </Border>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="Листинги кода">
                    <DockPanel Background="#F5F5F5" Margin="24">
                        <Border DockPanel.Dock="Top" Background="White" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="6" Padding="16,12" Margin="0,0,0,16">
                            <DockPanel>
                                <Button DockPanel.Dock="Right" Content="Выбрать папку" Classes="accent" Command="{Binding ParseCodeFolderCommand}"/>
                                <StackPanel Spacing="2">
                                    <TextBlock Text="Исходный код" FontWeight="SemiBold" FontSize="14" Foreground="#1A1A1A"/>
                                    <TextBlock Text="Выберите папку с проектом" FontSize="12" Foreground="#888888"/>
                                </StackPanel>
                            </DockPanel>
                        </Border>

                        <Border Background="White" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="6">
                            <ListBox ItemsSource="{Binding CodeListings}" Background="Transparent" BorderThickness="0">
                                <ListBox.ItemTemplate>
                                    <DataTemplate x:DataType="models:CodeListing">
                                        <StackPanel Orientation="Horizontal" Spacing="10" Margin="4,2">
                                            <CheckBox IsChecked="{Binding IsSelected}"/>
                                            <TextBlock Text="{Binding RelativePath}" Foreground="#333333" VerticalAlignment="Center" FontFamily="Consolas, monospace" FontSize="13"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Border>
                    </DockPanel>
                </TabItem>

            </TabControl>
        </Grid>
    </DockPanel>
</Window>
