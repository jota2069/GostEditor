<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="GostEditor.UI.Views.DocumentPageView">

    <Border Margin="0,0,0,32" HorizontalAlignment="Center">
        <Border Background="White"
                BorderBrush="#BBBBBB"
                BorderThickness="1"
                Width="794"
                Height="1123"
                BoxShadow="0 4 16 0 #33000000">

            <Grid RowDefinitions="76,952,95">
                <Border Grid.Row="0"/>

                <Grid Grid.Row="1" ColumnDefinitions="113,*,38" Background="Transparent">

                    <Canvas x:Name="SelectionCanvas" Grid.Column="1" IsHitTestVisible="False"/>

                    <TextBlock Grid.Column="1"
                               x:Name="RichTextDisplay"
                               TextWrapping="Wrap"
                               FontFamily="Times New Roman"
                               FontSize="18.67"
                               LineHeight="28"
                               Padding="0"
                               Margin="0"
                               HorizontalAlignment="Stretch"
                               VerticalAlignment="Stretch"/>

                    <Border Grid.Column="1"
                            x:Name="CustomCaret"
                            Width="1"
                            Background="Black"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Top"
                            IsHitTestVisible="False">
                        <Border.Styles>
                            <Style Selector="Border">
                                <Style.Animations>
                                    <Animation Duration="0:0:1" IterationCount="Infinite">
                                        <KeyFrame Cue="0%"><Setter Property="Opacity" Value="1.0"/></KeyFrame>
                                        <KeyFrame Cue="50%"><Setter Property="Opacity" Value="0.0"/></KeyFrame>
                                        <KeyFrame Cue="100%"><Setter Property="Opacity" Value="1.0"/></KeyFrame>
                                    </Animation>
                                </Style.Animations>
                            </Style>
                        </Border.Styles>
                    </Border>

                    <Border Grid.Column="1"
                            x:Name="MouseHitLayer"
                            Background="Transparent"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Stretch"
                            ZIndex="10"/>

                    <TextBox Grid.Column="1"
                             x:Name="PageTextBox"
                             IsHitTestVisible="False"
                             FocusAdorner="{x:Null}"
                             AcceptsReturn="True"
                             AcceptsTab="True"
                             TextWrapping="Wrap"
                             Background="Transparent"
                             Foreground="Transparent"
                             CaretBrush="Transparent"
                             SelectionBrush="Transparent"
                             BorderThickness="0"
                             FontFamily="Times New Roman"
                             FontSize="18.67"
                             VerticalContentAlignment="Top"
                             HorizontalAlignment="Stretch"
                             VerticalAlignment="Stretch"
                             Padding="0"
                             Margin="0"
                             LineHeight="28"
                             ScrollViewer.VerticalScrollBarVisibility="Disabled"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <TextBox.Styles>
                            <Style Selector="TextBox /template/ Border#PART_BorderElement">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="BorderThickness" Value="0"/>
                            </Style>
                            <Style Selector="TextBox:focus /template/ Border#PART_BorderElement">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="BorderThickness" Value="0"/>
                            </Style>
                        </TextBox.Styles>
                    </TextBox>
                </Grid>

                <Grid Grid.Row="2" ColumnDefinitions="113,*,38">
                    <TextBlock Grid.Column="1"
                               x:Name="PageNumberText"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               FontFamily="Times New Roman"
                               FontSize="18.67"
                               Foreground="#111111"/>
                </Grid>
            </Grid>
        </Border>
    </Border>

</UserControl>
